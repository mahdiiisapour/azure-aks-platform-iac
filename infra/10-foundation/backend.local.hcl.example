# Copy this file to backend.local.hcl and replace the storage account name with
# the value from infra/00-bootstrap:
#
# terraform -chdir=../00-bootstrap output -raw storage_account_name
#
# backend.local.hcl is intentionally ignored by Git because it is local
# environment configuration for Terraform backend initialisation.
#
# Do not add secrets, access keys, SAS tokens, client secrets, tenant IDs,
# subscription IDs, or other credentials to this file.

resource_group_name  = "rg-aks-platform-bootstrap-neu"
storage_account_name = "<read-from-00-bootstrap-output>"
container_name       = "tfstate"
key                  = "foundation/terraform.tfstate"
use_azuread_auth     = true

